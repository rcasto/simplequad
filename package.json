{
  "name": "simplequad",
  "version": "3.0.0",
  "description": "TypeScript quadtree with SAT collision detection and MTV output. Zero dependencies.",
  "main": "dist/simplequad.umd.js",
  "module": "dist/simplequad.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/simplequad.esm.js",
      "require": "./dist/simplequad.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && npm run build:bundles && npm run build:types",
    "build:bundles": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepack": "npm run test && npm run build",
    "benchmark": "tsx benchmarks/index.ts"
  },
  "author": "Richie Casto (https://github.com/rcasto)",
  "homepage": "https://rcasto.github.io/simplequad/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcasto/simplequad.git"
  },
  "keywords": [
    "quadtree",
    "2d-collision",
    "collision-detection",
    "sat",
    "minimum-translation-vector",
    "game-dev",
    "canvas",
    "spatial-index",
    "typescript",
    "2d-collision-library",
    "quadtree-js",
    "quadtree-lib"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist/",
    "src/"
  ]
}
